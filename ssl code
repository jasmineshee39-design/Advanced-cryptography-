import ssl
import socket
import threading
import time
from datetime import datetime, timedelta, timezone
from cryptography import x509
from cryptography.x509.oid import NameOID
from cryptography.hazmat.primitives import hashes, serialization
from cryptography.hazmat.primitives.asymmetric import rsa

# Configuration constants
HOST = "127.0.0.1"  # Localhost
PORT = 8443  # Standard alternative HTTPS port
CERT_FILE = "server.crt"
KEY_FILE = "server.key"


def generate_self_signed_cert():
    """Generates a temporary self-signed SSL certificate and private key."""
    print("[System] Generating self-signed SSL certificate...")
    private_key = rsa.generate_private_key(public_exponent=65537, key_size=2048)

    # Structure certificate details
    subject = issuer = x509.Name(
        [
            x509.NameAttribute(NameOID.COUNTRY_NAME, "US"),
            x509.NameAttribute(NameOID.STATE_OR_PROVINCE_NAME, "California"),
            x509.NameAttribute(NameOID.LOCALITY_NAME, "San Francisco"),
            x509.NameAttribute(NameOID.ORGANIZATION_NAME, "My Demo App"),
            x509.NameAttribute(NameOID.COMMON_NAME, HOST),
        ]
    )

    cert = (
        x509.CertificateBuilder()
        .subject_name(subject)
        .issuer_name(issuer)
        .public_key(private_key.public_key())
        .serial_number(x509.random_serial_number())
        .not_valid_before(datetime.now(timezone.utc))
        .not_valid_after(datetime.now(timezone.utc) + timedelta(days=1))
        .add_extension(
            x509.SubjectAlternativeName([x509.DNSName(HOST)]), critical=False
        )
        .sign(private_key, hashes.SHA256())
    )

    # Save Private Key
    with open(KEY_FILE, "wb") as f:
        f.write(
            private_key.private_bytes(
                encoding=serialization.Encoding.PEM,
                format=serialization.PrivateFormat.TraditionalOpenSSL,
                encryption_algorithm=serialization.NoEncryption(),
            )
        )

    # Save Certificate
    with open(CERT_FILE, "wb") as f:
        f.write(cert.public_bytes(serialization.Encoding.PEM))
    print("[System] SSL Certificate and Key saved successfully.\n")


def run_ssl_server():
    """Configures and boots up an SSL-encrypted server."""
    # 1. Initialize modern SSL Context for server use
    context = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
    context.load_cert_chain(certfile=CERT_FILE, keyfile=KEY_FILE)

    # 2. Bind standard TCP socket
    bind_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    bind_socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    bind_socket.bind((HOST, PORT))
    bind_socket.listen(5)
    print(f"[Server] SSL Server listening on port {PORT}...")

    # 3. Accept connection and wrap it in an SSL layer
    conn, addr = bind_socket.accept()
    try:
        with context.wrap_socket(conn, server_side=True) as secure_socket:
            print(f"[Server] Secure TLS connection established with {addr}")
            data = secure_socket.recv(1024).decode("utf-8")
            print(f"[Server] Received Encrypted Payload: '{data}'")

            # Reply back securely
            secure_socket.sendall(b"Hello Client! Your data was safe with me.")
    except Exception as e:
        print(f"[Server Error] {e}")
    finally:
        bind_socket.close()


def run_ssl_client():
    """Configures and runs an SSL client that connects to the server."""
    time.sleep(1)  # Ensure the server boots up first

    # 1. Create client SSL context
    context = ssl.SSLContext(ssl.PROTOCOL_TLS_CLIENT)

    # Since it's a self-signed certificate, we tell the client context to trust it directly
    context.load_verify_locations(cafile=CERT_FILE)

    # 2. Establish connection
    raw_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    print("[Client] Connecting to SSL Server...")

    try:
        # 3. Wrap socket and complete the TLS Handshake
        with context.wrap_socket(raw_socket, server_hostname=HOST) as ssl_sock:
            ssl_sock.connect((HOST, PORT))
            print(
                f"[Client] TLS Handshake Complete. Cipher used: {ssl_sock.cipher()[0]}"
            )

            # Send secret message
            message = "Secret Password: 12345"
            ssl_sock.sendall(message.encode("utf-8"))

            # Receive server answer
            response = ssl_sock.recv(1024).decode("utf-8")
            print(f"[Client] Server responded: '{response}'")
    except Exception as e:
        print(f"[Client Error] {e}")


if __name__ == "__main__":
    # Generate keys dynamically
    generate_self_signed_cert()

    # Spin up Server and Client on separate threads to watch them communicate
    server_thread = threading.Thread(target=run_ssl_server)
    client_thread = threading.Thread(target=run_ssl_client)

    server_thread.start()
    client_thread.start()

    server_thread.join()
    client_thread.join()
    print("\n[System] SSL demonstration execution complete.")