import os
from cryptography.hazmat.primitives.asymmetric import rsa, padding
from cryptography.hazmat.primitives import hashes
from cryptography.hazmat.primitives.serialization import load_pem_public_key, load_pem_private_key
from cryptography.exceptions import InvalidSignature

class DocumentValidator:
    @staticmethod
    def generate_authority_keys():
        """Generates a secure keypair representing a trusted document issuer."""
        private_key = rsa.generate_private_key(
            public_key_exponent=65537,
            key_size=2048
        )
        return private_key, private_key.public_key()

    @staticmethod
    def create_validation_signature(file_path: str, private_key) -> bytes:
        """
        Streams a local document to calculate its SHA-256 hash footprint, 
        then signs it using the authority's Private Key.
        """
        hash_engine = hashes.SHA256()
        
        # Stream the file in chunks to safely handle massive document sizes without memory bloating
        with open(file_path, "rb") as f:
            for chunk in iter(lambda: f.read(4096), b""):
                hash_engine.update(chunk)
        document_hash = hash_engine.finalize()

        # Sign the final document hash payload using PSS padding
        signature = private_key.sign(
            document_hash,
            padding.PSS(
                mgf=padding.MGF1(hashes.SHA256()),
                salt_length=padding.PSS.MAX_LENGTH
            ),
            hashes.SHA256()
        )
        return signature

    @staticmethod
    def validate_document(file_path: str, signature: bytes, public_key) -> bool:
        """
        Re-hashes the document file and validates it against the digital signature 
        using the authority's Public Key.
        """
        hash_engine = hashes.SHA256()
        
        if not os.path.exists(file_path):
            print(f"[-] Validation Error: Target file '{file_path}' does not exist.")
            return False

        with open(file_path, "rb") as f:
            for chunk in iter(lambda: f.read(4096), b""):
                hash_engine.update(chunk)
        document_hash = hash_engine.finalize()

        try:
            # Mathematical verification check
            public_key.verify(
                signature,
                document_hash,
                padding.PSS(
                    mgf=padding.MGF1(hashes.SHA256()),
                    salt_length=padding.PSS.MAX_LENGTH
                ),
                hashes.SHA256()
            )
            return True
        except InvalidSignature:
            return False


