import re
import math

class PasswordSecurityTester:
    def __init__(self, common_passwords_file=None):
        # A small sample list of notoriously common compromised passwords
        self.blacklist = {
            "123456", "password", "password123", "qwerty", 
            "letmein123", "admin", "welcome", "marina"
        }
        
    def calculate_entropy(self, password: str) -> float:
        """
        Calculates the Shannon Entropy of a password to evaluate its true 
        mathematical randomness and resistance to brute-force guessing.
        """
        if not password:
            return 0.0
            
        # Determine the size of the character pool used (Pool Size 'R')
        pool_size = 0
        if re.search(r'[a-z]', password): pool_size += 26
        if re.search(r'[A-Z]', password): pool_size += 26
        if re.search(r'[0-9]', password): pool_size += 10
        if re.search(r'[^a-zA-Z0-9]', password): pool_size += 33 # Standard special chars
        
        # Calculate Entropy: E = L * log2(R) where L is password length
        entropy = len(password) * math.log2(pool_size) if pool_size > 0 else 0
        return entropy

    def check_complexity_rules(self, password: str) -> dict:
        """Evaluates traditional policy complexity compliance matrix indicators."""
        checks = {
            "length_ok": len(password) >= 12,
            "has_upper": bool(re.search(r'[A-Z]', password)),
            "has_lower": bool(re.search(r'[a-z]', password)),
            "has_digit": bool(re.search(r'[0-9]', password)),
            "has_special": bool(re.search(r'[^a-zA-Z0-9]', password))
        }
        return checks

    def audit_password(self, password: str):
        """Executes a full adversarial security assessment of the targeted password."""
        print(f"\n{'='*20} SECURITY AUDIT REPORT {'='*20}")
        print(f"Target Password: '{password}'")
        
        # 1. Dictionary Check / Blacklist Verification
        if password.lower() in self.blacklist:
            print("❌ STATUS: CRITICAL FAILURE")
            print(" -> Reason: This password is a known compromised credential found on public leak lists.")
            return

        # 2. Complexity Rule Analysis
        rules = self.check_complexity_rules(password)
        print("\n[+] Policy Complexity Validation:")
        print(f" -> Minimum Length (>=12 chars): {'Passing ✅' if rules['length_ok'] else 'FAIL ❌'}")
        print(f" -> Uppercase Letters (A-Z)    : {'Passing ✅' if rules['has_upper'] else 'FAIL ❌'}")
        print(f" -> Lowercase Letters (a-z)    : {'Passing ✅' if rules['has_lower'] else 'FAIL ❌'}")
        print(f" -> Numeric Digits (0-9)       : {'Passing ✅' if rules['has_digit'] else 'FAIL ❌'}")
        print(f" -> Special Characters (#,!,?): {'Passing ✅' if rules['has_special'] else 'FAIL ❌'}")

        # 3. Calculate Shannon Entropy
        entropy_bits = self.calculate_entropy(password)
        print(f"\n[+] Information Theoretical Security:")
        print(f" -> Mathematical Entropy Score: {entropy_bits:.2f} bits")
        
        # Rate strength based on standard NIST/OWASP boundaries
        if entropy_bits >= 60:
            print(" -> Strength Classification   : EXCELLENT (Strongly resists cracking) 💪")
        elif entropy_bits >= 40:
            print(" -> Strength Classification   : MODERATE (Acceptable, but could be longer) ⚠️")
        else:
            print(" -> Strength Classification   : WEAK (Easily guessable by standard hardware) ❌")


# --- Testing Runtime Interface ---
if __name__ == "__main__":
    tester = PasswordSecurityTester()
    
    print("=== Automated Password Security Testing Lab ===")
    
    # Test Scenario 1: A structurally weak password
    tester.audit_password("Password123")
    
    # Test Scenario 2: A long but simple passphrase (Modern Security Practice)
    tester.audit_password("correct-horse-battery-staple")
    
    # Test Scenario 3: Custom Interactive User Testing
    print("\n" + "="*50)
    user_test = input("Enter a password to test live against the analyzer: ").strip()
    if user_test:
        tester.audit_password(user_test)