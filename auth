import sqlite3
import bcrypt

class AuthenticationSystem:
    def __init__(self, db_name="users_vault.db"):
        self.db_name = db_name
        self.init_database()

    def init_database(self):
        """Creates the secure user table schema if it does not already exist."""
        with sqlite3.connect(self.db_name) as conn:
            cursor = conn.cursor()
            # Create table with unique username constraint
            cursor.execute("""
                CREATE TABLE IF NOT EXISTS users (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    username TEXT UNIQUE NOT NULL,
                    password_hash TEXT NOT NULL
                )
            """)
            conn.commit()

    def register_user(self, username, plain_password):
        """Handles account creation, password hashing, and DB commitment."""
        # 1. Sanitize string inputs to lowercase for uniform lookup
        username_clean = username.strip().lower()
        
        # 2. Cryptographically hash the incoming plain text password
        password_bytes = plain_password.encode('utf-8')
        salt = bcrypt.gensalt(rounds=12)
        hashed_bytes = bcrypt.hashpw(password_bytes, salt)
        stored_hash_string = hashed_bytes.decode('utf-8')

        # 3. Securely write records to the DB using parameterized queries to block SQLi
        try:
            with sqlite3.connect(self.db_name) as conn:
                cursor = conn.cursor()
                cursor.execute(
                    "INSERT INTO users (username, password_hash) VALUES (?, ?)",
                    (username_clean, stored_hash_string)
                )
                conn.commit()
            return True, "Registration successful! Account created."
        except sqlite3.IntegrityError:
            return False, "Error: That username is already taken."

    def authenticate_user(self, username, plain_password):
        """Validates incoming login credentials against the database record logs."""
        username_clean = username.strip().lower()

        # 1. Fetch user record based on username
        with sqlite3.connect(self.db_name) as conn:
            cursor = conn.cursor()
            cursor.execute("SELECT password_hash FROM users WHERE username = ?", (username_clean,))
            record = cursor.fetchone()

        # If username doesn't exist in the data columns
        if not record:
            return False, "Invalid username or password configuration."

        stored_hash_string = record[0]

        # 2. Perform constant-time verification loop using Bcrypt
        password_bytes = plain_password.encode('utf-8')
        hash_bytes = stored_hash_string.encode('utf-8')

        if bcrypt.checkpw(password_bytes, hash_bytes):
            return True, f"Authentication Success! Welcome back, {username}."
        else:
            return False, "Invalid username or password configuration."


# --- Interactive Terminal User Interface ---
def run_auth_loop():
    auth = AuthenticationSystem()
    print("=" * 45)
    print("      S E C U R E   L O G I N   S Y S T E M      ")
    print("=" * 45)

    while True:
        print("\n[1] Register New Account\n[2] User Login\n[3] Exit System")
        choice = input("Select an option (1-3): ").strip()

        if choice == "1":
            print("\n--- Account Registration Panel ---")
            user = input("Choose a username: ")
            pwd = input("Choose a password: ")
            if not user or not pwd:
                print("❌ Usernames and passwords cannot be blank.")
                continue
            
            success, msg = auth.register_user(user, pwd)
            print(f"{'✅' if success else '❌'} {msg}")

        elif choice == "2":
            print("\n--- User Portal Login ---")
            user = input("Enter username: ")
            pwd = input("Enter password: ")
            
            success, msg = auth.authenticate_user(user, pwd)
            if success:
                print(f"✅ {msg}")
                print(">>> [ACCESS GRANTED] Redirecting to Dashboard... <<<")
            else:
                # Security Best Practice: Use ambiguous error messages to prevent account enumeration
                print(f"❌ {msg}")

        elif choice == "3":
            print("\nShutting down security portal services. Goodbye!")
            break
        else:
            print("❌ Invalid menu choice index selection.")

if __name__ == "__main__":
    run_auth_loop()