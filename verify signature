from cryptography.hazmat.primitives.asymmetric import rsa, padding
from cryptography.hazmat.primitives import hashes
from cryptography.hazmat.primitives.serialization import load_pem_public_key
from cryptography.exceptions import InvalidSignature

class SignatureVerifier:
    @staticmethod
    def verify_payload(message_str: str, signature_hex: str, public_key_pem: str) -> bool:
        """
        Verifies an incoming message payload against its digital signature hex string.
        """
        # 1. Convert inputs from transmission formats (strings/hex) to raw bytes
        message_bytes = message_str.encode('utf-8')
        try:
            signature_bytes = bytes.fromhex(signature_hex)
        except ValueError:
            print("[-] Error: Signature string format is not valid Hexadecimal.")
            return False

        try:
            # 2. Deserializes the Public Key string back into an active RSA Public Key Object
            public_key_object = load_pem_public_key(public_key_pem.encode('utf-8'))
            
            # 3. Perform the mathematical verification
            # If the signature matches the message hash, this function returns None.
            # If any bit is tampered with, it throws an InvalidSignature exception.
            public_key_object.verify(
                signature_bytes,
                message_bytes,
                padding.PSS(
                    mgf=padding.MGF1(hashes.SHA256()),
                    salt_length=padding.PSS.MAX_LENGTH
                ),
                hashes.SHA256()
            )
            return True
            
        except InvalidSignature:
            return False
        except Exception as e:
            print(f"[-] Architectural error parsing verification parameters: {e}")
            return False


