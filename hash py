import hashlib

def generate_sha256(text_input):
    """Generates a standard SHA-256 hash from a string input."""
    # 1. Convert the string into raw bytes using UTF-8 encoding
    data_bytes = text_input.encode('utf-8')
    
    # 2. Feed the bytes into the SHA-256 hash object
    hash_object = hashlib.sha256(data_bytes)
    
    # 3. Return the fixed-length hexadecimal string representation
    return hash_object.hexdigest()


def hash_large_file(file_path):
    """
    Streams a large file in chunks to compute its hash without 
    overloading your computer's RAM memory footprint.
    """
    # Use SHA-512 for enhanced security or file integrity verification
    hash_object = hashlib.sha512()
    
    try:
        with open(file_path, "rb") as f:
            # Read the file in small 4096-byte blocks
            for chunk in iter(lambda: f.read(4096), b""):
                hash_object.update(chunk)
        return hash_object.hexdigest()
    except FileNotFoundError:
        return None


def secure_password_hash(password, salt):
    """
    Applies a 'Salt' to a password hash. Salting appends unique random data
    to the password, completely neutralizing pre-computed Rainbow Table attacks.
    """
    # Combine password bytes and unique salt bytes
    salted_data = password.encode('utf-8') + salt
    
    # Generate the salted digest
    return hashlib.sha256(salted_data).hexdigest()


